{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://animeatlas.dev/schemas/media-aliases/v1.json",
  "title": "AnimeAtlas Media Aliases",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "media_id", "aliases"],
  "properties": {
    "$schema": { "type": "string" },
    "schema": { "const": "media-aliases/v1" },
    "media_id": { "type": "string", "pattern": "^media-[0-9]{6}$" },
    "aliases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["value", "language", "type", "source", "confidence"],
        "properties": {
          "value": { "type": "string", "minLength": 1 },
          "language": { "type": "string", "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$" },
          "type": {
            "enum": ["official", "localized", "romaji", "nickname", "alternative", "legacy"]
          },
          "source": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
