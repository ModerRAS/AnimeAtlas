{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://animeatlas.dev/schemas/provider-manifest/v1.json",
  "title": "AnimeAtlas Provider Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "provider", "display_name", "entity_types", "capabilities"],
  "properties": {
    "schema": { "const": "provider-manifest/v1" },
    "provider": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "display_name": { "type": "string", "minLength": 1 },
    "entity_types": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["anime"] },
      "uniqueItems": true
    },
    "capabilities": {
      "type": "array",
      "items": {
        "enum": [
          "search",
          "resolve_ids",
          "fetch_metadata",
          "fetch_images",
          "fetch_relations",
          "bulk_import",
          "incremental_update"
        ]
      },
      "uniqueItems": true
    },
    "notes": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
